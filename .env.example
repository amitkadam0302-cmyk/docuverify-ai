APP_NAME=DocuVerify AI
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
API_PREFIX=/api
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql+psycopg2://docuverify:docuverify@localhost:5432/docuverify_ai
JWT_SECRET=replace-with-a-long-random-secret-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
STORAGE_CACHE_DIR=storage_cache
REPORT_DIR=reports
PROCESSED_DIR=processed
GENERATED_QR_DIR=generated_qr
PUBLIC_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000/api
CONTACT_EMAIL=support@docuverify.ai
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=
