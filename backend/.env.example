ENVIRONMENT=development
DEBUG=false
APP_NAME=DocuVerify AI
APP_VERSION=0.1.0
API_PREFIX=/api

DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/docuverify_ai
JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8000
CONTACT_EMAIL=support@docuverify.ai

STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
STORAGE_CACHE_DIR=storage_cache
REPORT_DIR=reports
PROCESSED_DIR=processed
GENERATED_QR_DIR=generated_qr
MAX_UPLOAD_SIZE_MB=10

AUTH_RATE_LIMIT_PER_MINUTE=10
UPLOAD_RATE_LIMIT_PER_MINUTE=20
LOG_LEVEL=INFO
SENTRY_DSN=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=
